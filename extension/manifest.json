{
  "manifest_version": 3,
  "name": "EarlybirdTalent",
  "description": "Capture LinkedIn profiles directly into your EarlybirdTalent database",
  "version": "1.1.0",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://earlybird-talent.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/in/*",
        "https://www.linkedin.com/sales/search/*",
        "https://www.linkedin.com/sales/lists/*",
        "https://www.linkedin.com/sales/lead-lists/*",
        "https://www.linkedin.com/sales/people/*"
      ],
      "js": ["classify.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
